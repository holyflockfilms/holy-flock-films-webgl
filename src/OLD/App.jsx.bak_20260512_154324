function useWindowSize() {
  const [size, setSize] = useState(() => ({
    width: typeof window === "undefined" ? 1440 : window.innerWidth,
    height: typeof window === "undefined" ? 900 : window.innerHeight,
  }));

  useEffect(() => {
    const update = () => setSize({ width: window.innerWidth, height: window.innerHeight });
    update();
    window.addEventListener("resize", update);
    return () => window.removeEventListener("resize", update);
  }, []);

  return size;
}

function createFilmTexture({ film, card, index }) {
  const canvas = document.createElement("canvas");
  canvas.width = 1024;
  canvas.height = 1024;
  const ctx = canvas.getContext("2d");
  const rand = mulberry32(2000 + card.seed);

  ctx.fillStyle = "#f4f0e6";
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  const gradient = ctx.createLinearGradient(0, 0, 1024, 1024);
  gradient.addColorStop(0, `${film.tone}33`);
  gradient.addColorStop(0.45, "#f8f4ea");
  gradient.addColorStop(1, `${film.tone}88`);
  ctx.fillStyle = gradient;
  ctx.fillRect(0, 0, 1024, 1024);

  ctx.save();
  ctx.translate(96 + rand() * 90, 92 + rand() * 70);
  ctx.rotate((rand() - 0.5) * 0.18);
  ctx.fillStyle = `${film.tone}b8`;
  ctx.fillRect(0, 0, 780, 610);

  ctx.globalCompositeOperation = "screen";
  ctx.fillStyle = "rgba(255,255,255,0.38)";
  for (let i = 0; i < 15; i++) {
    const x = rand() * 770;
    const y = rand() * 590;
    const r = 22 + rand() * 120;
    if (i % 3 === 0) {
      ctx.fillRect(x - r / 2, y - r / 2, r * 1.6, r * 0.52);
    } else {
      ctx.beginPath();
      ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fill();
    }
  }
  ctx.globalCompositeOperation = "multiply";
  ctx.fillStyle = "rgba(0,0,0,0.16)";
  for (let i = 0; i < 8; i++) {
    ctx.fillRect(rand() * 780, rand() * 610, 20 + rand() * 120, 2 + rand() * 14);
  }
  ctx.globalCompositeOperation = "source-over";
  ctx.strokeStyle = "rgba(26,23,20,0.72)";
  ctx.lineWidth = 9;
  ctx.strokeRect(0, 0, 780, 610);
  ctx.restore();

  ctx.strokeStyle = "rgba(26,23,20,0.22)";
  ctx.lineWidth = 3;
  ctx.lineCap = "round";
  for (let i = 0; i < 42; i++) {
    ctx.beginPath();
    const sx = rand() * 1024;
    const sy = rand() * 1024;
    ctx.moveTo(sx, sy);
    ctx.bezierCurveTo(
      sx + (rand() - 0.5) * 140,
      sy + (rand() - 0.5) * 140,
      sx + (rand() - 0.5) * 260,
      sy + (rand() - 0.5) * 260,
      sx + (rand() - 0.5) * 360,
      sy + (rand() - 0.5) * 360,
    );
    ctx.stroke();
  }

  ctx.fillStyle = "rgba(26,23,20,0.92)";
  ctx.font = "900 48px serif";
  ctx.fillText(`${film.number} / ${card.label}`, 56, 84);

  ctx.font = card.type === "poster" ? "900 98px serif" : "900 72px serif";
  const title = film.title.toUpperCase();
  const words = title.split(" ");
  const lines = [];
  let line = "";
  words.forEach((word) => {
    const test = `${line} ${word}`.trim();
    if (test.length > 16 && line) {
      lines.push(line);
      line = word;
    } else {
      line = test;
    }
  });
  lines.push(line);
  lines.slice(0, 4).forEach((txt, i) => {
    ctx.fillText(txt, 52, 760 + i * 78);
  });

  ctx.font = "italic 44px serif";
  ctx.fillStyle = `${film.tone}`;
  ctx.fillText(`${film.year} — ${film.format}`, 56, 962);

  const image = ctx.getImageData(0, 0, canvas.width, canvas.height);
  const data = image.data;
  for (let i = 0; i < data.length; i += 4 * 11) {
    const n = rand() * 34 - 17;
    data[i] = clamp(data[i] + n, 0, 255);
    data[i + 1] = clamp(data[i + 1] + n, 0, 255);
    data[i + 2] = clamp(data[i + 2] + n, 0, 255);
  }
  ctx.putImageData(image, 0, 0);

  const texture = new THREE.CanvasTexture(canvas);
  texture.colorSpace = THREE.SRGBColorSpace;
  texture.anisotropy = 8;
  texture.needsUpdate = true;
  return texture;
}

function createDoodleTexture() {
  const canvas = document.createElement("canvas");
  canvas.width = 4096;
  canvas.height = 2560;
  const ctx = canvas.getContext("2d");
  const rand = mulberry32(666);
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  const words = ["AGOR", "CUT", "HOLD", "RITUAL", "SAINT", "RUIN", "FLOCK", "LIGHT", "FIELD", "SIGNAL"];
  ctx.strokeStyle = "rgba(26,23,20,0.22)";
  ctx.fillStyle = "rgba(26,23,20,0.18)";
  ctx.lineWidth = 4;
  ctx.lineCap = "round";

  for (let i = 0; i < 220; i++) {
    const x = rand() * canvas.width;
    const y = rand() * canvas.height;
    ctx.save();
    ctx.translate(x, y);
    ctx.rotate((rand() - 0.5) * Math.PI * 2);
    const kind = i % 9;
    if (kind === 0) {
      ctx.font = `${42 + rand() * 42}px Caveat, cursive`;
      ctx.fillText(words[Math.floor(rand() * words.length)], 0, 0);
    } else if (kind === 1) {
      ctx.beginPath();
      ctx.moveTo(0, -30);
      for (let p = 0; p < 5; p++) {
        ctx.lineTo(Math.cos((p * 2 * Math.PI) / 5 - Math.PI / 2) * 52, Math.sin((p * 2 * Math.PI) / 5 - Math.PI / 2) * 52);
        ctx.lineTo(Math.cos(((p + 0.5) * 2 * Math.PI) / 5 - Math.PI / 2) * 22, Math.sin(((p + 0.5) * 2 * Math.PI) / 5 - Math.PI / 2) * 22);
      }
      ctx.closePath();
      ctx.stroke();
    } else if (kind === 2) {
      ctx.beginPath();
      ctx.arc(0, 0, 22 + rand() * 85, 0, Math.PI * 2);
      ctx.stroke();
    } else if (kind === 3) {
      ctx.beginPath();
      ctx.moveTo(0, -70);
      ctx.lineTo(62, 42);
      ctx.lineTo(-62, 42);
      ctx.closePath();
      ctx.stroke();
    } else if (kind === 4) {
      ctx.beginPath();
      for (let a = 0; a < Math.PI * 2; a += Math.PI / 3) {
        const px = Math.cos(a) * 64;
        const py = Math.sin(a) * 64;
        if (a === 0) ctx.moveTo(px, py);
        else ctx.lineTo(px, py);
      }
      ctx.closePath();
      ctx.stroke();
    } else {
      ctx.beginPath();
      ctx.moveTo(0, 0);
      for (let j = 0; j < 10; j++) {
        ctx.lineTo((rand() - 0.5) * 300, (rand() - 0.5) * 300);
      }
      ctx.stroke();
    }
    ctx.restore();
  }

  const texture = new THREE.CanvasTexture(canvas);
  texture.colorSpace = THREE.SRGBColorSpace;
  texture.needsUpdate = true;
  return texture;
}

