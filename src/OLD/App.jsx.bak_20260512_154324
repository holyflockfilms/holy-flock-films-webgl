function CardMesh({ film, card, index, scale, proximity, clusterActivation, cursorWorld, hoveredIndex, setHovered, openFilm, suppressClickRef, setCursorMode, setHoverType }) {
  const ref = useRef();
  const activationRef = useRef(0);
  const siblingRef = useRef(0);
  const texture = useMemo(() => createFilmTexture({ film, card, index }), [film, card, index]);
  const temp = useMemo(() => new THREE.Vector3(), []);

  useFrame(() => {
    if (!ref.current) return;
    const clusterX = film.position[0] * scale;
    const clusterY = film.position[1] * scale;
    const localCursorX = cursorWorld.x - clusterX;
    const localCursorY = cursorWorld.y - clusterY;
    const isHovered = hoveredIndex === index;

    // Connected-cluster behaviour:
    // hovering one card activates the whole image family, while the hovered card
    // still gets the strongest magnetic pull and scale.
    const hoverDistance = hoveredIndex === null ? 999 : Math.abs(index - hoveredIndex);
    const siblingInfluenceTarget = hoveredIndex === null ? 0 : Math.max(0, 1 - hoverDistance * 0.24);
    const delaySpeed = 0.055 + index * 0.009;

    activationRef.current = THREE.MathUtils.lerp(
      activationRef.current,
      clusterActivation,
      delaySpeed
    );

    siblingRef.current = THREE.MathUtils.lerp(
      siblingRef.current,
      siblingInfluenceTarget,
      delaySpeed * 1.4
    );

    const active = activationRef.current;
    const siblingInfluence = siblingRef.current;

    const posterMultiplier = card.type === "poster" ? 1.08 : 1;
    const clusterGrow = 0.065 + (card.z / 8) * 0.055;
    const siblingScaleBoost = siblingInfluence * 0.09;
    const hoverBoost = isHovered ? 0.18 : 0;

    // Cluster-level magnet: the whole bunch leans toward the cursor.
    const leanX = localCursorX * 0.011 * active;
    const leanY = localCursorY * 0.011 * active;

    // Restrained bloom for all cards, with much stronger card-level magnetism.
    const baseX = (card.dx + card.spreadX * active * CLUSTER_SPREAD_STRENGTH) * scale;
    const baseY = (card.dy + card.spreadY * active * CLUSTER_SPREAD_STRENGTH) * scale;
    const pullLimit = 130 * scale;
    const pullStrength = isHovered ? 0.24 : siblingInfluence * 0.1;
    const pullX = clamp(localCursorX - baseX, -pullLimit, pullLimit) * pullStrength;
    const pullY = clamp(localCursorY - baseY, -pullLimit, pullLimit) * pullStrength;

    const depthBoost = 0.012 + (card.z / 8) * 0.038;
    const targetScale = posterMultiplier * (1 + active * clusterGrow + active * depthBoost + siblingScaleBoost + hoverBoost);
    const targetRotation = THREE.MathUtils.degToRad(card.rot * (1 - active * 0.7));
    const tx = baseX + leanX + pullX;
    const ty = baseY + leanY + pullY;
    const tz = card.z * 8;

    temp.set(tx, ty, tz);
    ref.current.position.lerp(temp, 0.14);
    ref.current.scale.x = THREE.MathUtils.lerp(ref.current.scale.x, targetScale, 0.12);
    ref.current.scale.y = THREE.MathUtils.lerp(ref.current.scale.y, targetScale, 0.12);
    ref.current.rotation.z = THREE.MathUtils.lerp(ref.current.rotation.z, targetRotation, 0.13);
  });

  return (
    <mesh
      ref={ref}
      renderOrder={100 + card.z}
      onPointerOver={(e) => {
        e.stopPropagation();
        setHovered(index);
        setHoverType("cluster");
        setCursorMode("view");
      }}
      onPointerOut={(e) => {
        e.stopPropagation();
        setHovered(null);
        setHoverType(null);
        setCursorMode("drag");
      }}
      onClick={(e) => {
        e.stopPropagation();
        if (!suppressClickRef.current) openFilm(film, index);
      }}
    >
      <planeGeometry args={[card.w * scale * (card.type === "poster" ? 1.05 : 1), card.h * scale * (card.type === "poster" ? 1.05 : 1)]} />
      <meshBasicMaterial map={texture} transparent depthWrite={false} toneMapped={false} />
    </mesh>
  );
}

function FilmCluster({ film, scale, cursorWorld, openFilm, suppressClickRef, setCursorMode, setHoverType }) {
  const [hovered, setHovered] = useState(null);
  const clusterX = film.position[0] * scale;
  const clusterY = film.position[1] * scale;
  const dist = Math.hypot(cursorWorld.x - clusterX, cursorWorld.y - clusterY);
  const proximity = 1 - smoothstep(0, CARD_RADIUS * scale, dist);
  const clusterActivation = Math.max(proximity, hovered !== null ? 1 : 0);
  const hitRadius = 430 * scale;

  return (
    <group position={[clusterX, clusterY, 0]}>
      <mesh
        position={[0, 0, -5]}
        onPointerOver={(e) => {
          e.stopPropagation();
          setHoverType("cluster");
          setCursorMode("view");
        }}
        onPointerOut={(e) => {
          e.stopPropagation();
          setHoverType(null);
          setCursorMode("drag");
        }}
        onClick={(e) => {
          e.stopPropagation();
          if (!suppressClickRef.current) openFilm(film, 0);
        }}
      >
        <circleGeometry args={[hitRadius, 64]} />
        <meshBasicMaterial transparent opacity={0} depthWrite={false} />
      </mesh>

      {film.cards.map((card, index) => (
        <CardMesh
          key={`${film.title}-${index}`}
          film={film}
          card={card}
          index={index}
          scale={scale}
          proximity={proximity}
          clusterActivation={clusterActivation}
          cursorWorld={cursorWorld}
          hoveredIndex={hovered}
          setHovered={setHovered}
          openFilm={openFilm}
          suppressClickRef={suppressClickRef}
          setCursorMode={setCursorMode}
          setHoverType={setHoverType}
        />
      ))}

      <group position={[0, -312 * scale, 20]} renderOrder={220}>
        <FilmLabel film={film} scale={scale} proximity={proximity} />
      </group>
    </group>
  );
}

function makeLabelTexture(film) {
  const canvas = document.createElement("canvas");
  canvas.width = 900;
  canvas.height = 180;
  const ctx = canvas.getContext("2d");
  ctx.clearRect(0, 0, 900, 180);
  ctx.fillStyle = "rgba(26,23,20,0.92)";
  ctx.font = "900 54px serif";
  ctx.fillText(`${film.number}. ${film.title.toUpperCase()}`, 0, 72);
  ctx.font = "italic 34px serif";
  ctx.fillStyle = "rgba(26,23,20,0.54)";
  ctx.fillText(`${film.year} / ${film.runtime} / ${film.format}`, 0, 124);
  const texture = new THREE.CanvasTexture(canvas);
  texture.colorSpace = THREE.SRGBColorSpace;
  return texture;
}

function FilmLabel({ film, scale, proximity }) {
  const ref = useRef();
  const texture = useMemo(() => makeLabelTexture(film), [film]);
  useFrame(() => {
    if (!ref.current) return;
    ref.current.material.opacity = THREE.MathUtils.lerp(ref.current.material.opacity, 0.15 + proximity * 0.85, 0.12);
    ref.current.scale.setScalar(THREE.MathUtils.lerp(ref.current.scale.x, 0.85 + proximity * 0.18, 0.12));
  });
  return (
    <mesh ref={ref} renderOrder={260}>
      <planeGeometry args={[450 * scale, 90 * scale]} />
      <meshBasicMaterial map={texture} transparent opacity={0.24} depthWrite={false} toneMapped={false} />
    </mesh>
  );
}

