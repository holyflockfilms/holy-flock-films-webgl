export default function HolyFlockDveinStyleSite() {
  const size = useWindowSize();
  const baseScale = clamp(size.width / REF_WIDTH, 0.6, 1.3);
  const legalMinZoom = useMemo(() => {
    const coverWidth = size.width / (BASE_WORLD.width * baseScale);
    const coverHeight = size.height / (BASE_WORLD.height * baseScale);
    return clamp(Math.max(coverWidth, coverHeight) * 1.015, MIN_ZOOM, MAX_ZOOM);
  }, [size.width, size.height, baseScale]);
  const introStartZoom = Math.max(INTRO_ZOOM_START, legalMinZoom);
  const [zoom, setZoom] = useState(introStartZoom);
  const [zoomTarget, setZoomTarget] = useState(introStartZoom);
  const safeZoom = clamp(zoom, legalMinZoom, MAX_ZOOM);
  const scale = baseScale * safeZoom;
  const worldWidth = BASE_WORLD.width * scale;
  const worldHeight = BASE_WORLD.height * scale;
  const maxPan = useMemo(() => ({
    x: Math.max(0, (worldWidth - size.width) / 2),
    y: Math.max(0, (worldHeight - size.height) / 2),
  }), [worldWidth, worldHeight, size.width, size.height]);

  const [pan, setPan] = useState({ x: 0, y: 0 });
  const [pointer, setPointer] = useState({ x: size.width / 2, y: size.height / 2 });
  const [cursorMode, setCursorMode] = useState("drag");
  const [hoverType, setHoverType] = useState(null);
  const [selected, setSelected] = useState(null);
  const [activeCard, setActiveCard] = useState(0);
  const [overlay, setOverlay] = useState(null);
  const [loading, setLoading] = useState(true);

  const dragging = useRef(false);
  const introZooming = useRef(true);
  const lastPointer = useRef({ x: 0, y: 0 });
  const downPointer = useRef({ x: 0, y: 0 });
  const velocity = useRef({ x: 0, y: 0 });
  const panRef = useRef(pan);
  const suppressClickRef = useRef(false);
  const hoverTypeRef = useRef(hoverType);

  useEffect(() => { panRef.current = pan; }, [pan]);
  useEffect(() => { hoverTypeRef.current = hoverType; }, [hoverType]);

  useEffect(() => {
    const timer = window.setTimeout(() => setLoading(false), 850);
    return () => window.clearTimeout(timer);
  }, []);

  useEffect(() => {
    setZoom((current) => clamp(current, legalMinZoom, MAX_ZOOM));
    setZoomTarget((current) => clamp(current, legalMinZoom, MAX_ZOOM));
  }, [legalMinZoom]);

  useEffect(() => {
    if (loading) return undefined;

    let raf;
    const duration = 4800;
    const started = performance.now();
    const ease = (t) => 1 - Math.pow(1 - t, 3);

    setZoom(introStartZoom);
    setZoomTarget(introStartZoom);
    introZooming.current = true;

    const tick = (now) => {
      if (!introZooming.current) return;
      const t = clamp((now - started) / duration, 0, 1);
      const nextZoom = introStartZoom + (INTRO_ZOOM_END - introStartZoom) * ease(t);
      setZoom(nextZoom);
      setZoomTarget(nextZoom);
      if (t < 1) raf = requestAnimationFrame(tick);
      else introZooming.current = false;
    };

    raf = requestAnimationFrame(tick);
    return () => cancelAnimationFrame(raf);
  }, [loading, introStartZoom]);

  useEffect(() => {
    let raf;
    const tick = () => {
      if (!introZooming.current) {
        setZoom((current) => {
          const next = current + (zoomTarget - current) * 0.075;
          return Math.abs(next - zoomTarget) < 0.001 ? zoomTarget : next;
        });
      }
      raf = requestAnimationFrame(tick);
    };
    raf = requestAnimationFrame(tick);
    return () => cancelAnimationFrame(raf);
  }, [zoomTarget]);

  const clampPan = useCallback((next) => ({
    x: clamp(next.x, -maxPan.x, maxPan.x),
    y: clamp(next.y, -maxPan.y, maxPan.y),
  }), [maxPan.x, maxPan.y]);

  useEffect(() => {
    const next = clampPan(panRef.current);
    panRef.current = next;
    setPan(next);
  }, [clampPan]);

  const cursorWorld = useMemo(() => ({
    x: pointer.x - size.width / 2 - pan.x,
    y: -(pointer.y - size.height / 2) - pan.y,
  }), [pointer.x, pointer.y, size.width, size.height, pan.x, pan.y]);

  const openFilm = useCallback((film) => {
    setOverlay(null);
    setSelected({ film });
    // DVEIN-style behaviour: clicking any part of a cluster opens the film page with the trailer active by default.
    setActiveCard("trailer");
    setCursorMode("default");
  }, []);

  const closeModal = useCallback(() => {
    setSelected(null);
    setCursorMode("drag");
  }, []);

  useEffect(() => {
    let raf;
    const tick = () => {
      if (!dragging.current) {
        const speed = Math.hypot(velocity.current.x, velocity.current.y);
        if (speed > 0.08) {
          const next = clampPan({
            x: panRef.current.x + velocity.current.x,
            y: panRef.current.y + velocity.current.y,
          });
          velocity.current.x *= 0.92;
          velocity.current.y *= 0.92;
          if (next.x === -maxPan.x || next.x === maxPan.x) velocity.current.x *= 0.25;
          if (next.y === -maxPan.y || next.y === maxPan.y) velocity.current.y *= 0.25;
          panRef.current = next;
          setPan(next);
        }
      }
      raf = requestAnimationFrame(tick);
    };
    raf = requestAnimationFrame(tick);
    return () => cancelAnimationFrame(raf);
  }, [clampPan, maxPan.x, maxPan.y]);

  useEffect(() => {
    const onKey = (e) => {
      if (e.key === "Escape") {
        if (selected) closeModal();
        else setOverlay(null);
      }
      if (selected && (e.key === "ArrowRight" || e.key === "ArrowLeft")) {
        setActiveCard((current) => {
          const count = selected.film.cards.length + 1; // trailer tab + image cards
          const currentIndex = current === "trailer" ? 0 : current + 1;
          const nextIndex = e.key === "ArrowRight"
            ? (currentIndex + 1) % count
            : (currentIndex - 1 + count) % count;
          return nextIndex === 0 ? "trailer" : nextIndex - 1;
        });
      }
    };
    window.addEventListener("keydown", onKey);
    return () => window.removeEventListener("keydown", onKey);
  }, [selected, closeModal]);

  const handlePointerDown = (e) => {
    if (e.target.closest?.("[data-ui='true']")) return;
    if (selected || overlay) return;
    dragging.current = true;
    suppressClickRef.current = false;
    lastPointer.current = { x: e.clientX, y: e.clientY };
    downPointer.current = { x: e.clientX, y: e.clientY };
    velocity.current = { x: 0, y: 0 };
    setCursorMode("dragging");
    e.currentTarget.setPointerCapture?.(e.pointerId);
  };

  const handlePointerMove = (e) => {
    setPointer({ x: e.clientX, y: e.clientY });
    if (dragging.current) {
      const dx = e.clientX - lastPointer.current.x;
      const dy = e.clientY - lastPointer.current.y;
      lastPointer.current = { x: e.clientX, y: e.clientY };
      const next = clampPan({ x: panRef.current.x + dx, y: panRef.current.y - dy });
      velocity.current = { x: dx * 0.92, y: -dy * 0.92 };
      panRef.current = next;
      setPan(next);
      setCursorMode("dragging");
      return;
    }
    if (!hoverTypeRef.current && !selected && !overlay) setCursorMode("drag");
  };

  const handlePointerUp = (e) => {
    if (!dragging.current) return;
    dragging.current = false;
    const moved = Math.hypot(e.clientX - downPointer.current.x, e.clientY - downPointer.current.y);
    const wasDrag = moved > CLICK_SUPPRESS_DISTANCE;
    suppressClickRef.current = wasDrag;

    // Robust cluster click fallback. This fixes cases where the WebGL mesh itself does not receive the click.
    if (!wasDrag && !selected && !overlay) {
      const worldX = e.clientX - size.width / 2 - panRef.current.x;
      const worldY = -(e.clientY - size.height / 2) - panRef.current.y;
      let nearest = null;
      let nearestDistance = Infinity;

      for (const film of FILMS) {
        const clusterX = film.position[0] * scale;
        const clusterY = film.position[1] * scale;
        const distance = Math.hypot(worldX - clusterX, worldY - clusterY);
        if (distance < nearestDistance) {
          nearest = film;
          nearestDistance = distance;
        }
      }

      if (nearest && nearestDistance < 430 * scale) {
        openFilm(nearest);
      }
    }

    window.setTimeout(() => { suppressClickRef.current = false; }, 90);
    if (!hoverTypeRef.current) setCursorMode("drag");
  };

  const handleWheel = (e) => {
    if (selected || overlay) return;
    introZooming.current = false;
    const direction = e.deltaY > 0 ? -1 : 1;
    const amount = Math.min(0.045, Math.abs(e.deltaY) * 0.00045);
    setZoomTarget((current) => clamp(current + direction * amount, legalMinZoom, MAX_ZOOM));
  };

  const navVisible = pointer.y > size.height * 0.72 || overlay !== null;

  return (
    <div className="siteRoot">
      <StyleBlock />
      <div
        className="desktopExperience"
        onPointerDown={handlePointerDown}
        onPointerMove={handlePointerMove}
        onPointerUp={handlePointerUp}
        onPointerCancel={handlePointerUp}
        onWheel={handleWheel}
      >
        <Scene
          pan={pan}
          scale={scale}
          cursorWorld={cursorWorld}
          openFilm={openFilm}
          suppressClickRef={suppressClickRef}
          setCursorMode={setCursorMode}
          setHoverType={setHoverType}
        />

        <div className="brandPlate" data-ui="true">
          <p>HOLY FLOCK FILMS</p>
          <span>Cardiff / Short films / Cult process wall</span>
        </div>

        <div className="coordinates" data-ui="true">
          <span>{Math.round((pan.x + maxPan.x) / Math.max(1, maxPan.x * 2) * 100)} / X</span>
          <span>{Math.round((pan.y + maxPan.y) / Math.max(1, maxPan.y * 2) * 100)} / Y</span>
        </div>

        <BottomNav
          visible={navVisible}
          overlay={overlay}
          setOverlay={(next) => {
            setSelected(null);
            setOverlay(next);
          }}
          setCursorMode={setCursorMode}
          setHoverType={setHoverType}
        />

        <AnimatePresence>
          {overlay === "manifesto" && <ManifestoOverlay close={() => setOverlay(null)} />}
          {overlay === "scores" && <ScoresOverlay close={() => setOverlay(null)} setCursorMode={setCursorMode} setHoverType={setHoverType} />}
          {overlay === "write" && <WriteOverlay close={() => setOverlay(null)} setCursorMode={setCursorMode} setHoverType={setHoverType} />}
        </AnimatePresence>

        <AnimatePresence>
          {selected && (
            <FilmModal
              selected={selected}
              activeCard={activeCard}
              setActiveCard={setActiveCard}
              close={closeModal}
              setCursorMode={setCursorMode}
              setHoverType={setHoverType}
            />
          )}
        </AnimatePresence>

        <CustomCursor mode={cursorMode} />
        <div className="grainOverlay" aria-hidden="true" />
        <LoadingGate loading={loading} />
      </div>
      <MobileFallback />
    </div>
  );
}

